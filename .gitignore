# =============================================================================
#  REAL-TIME INFERENCE FUNCTION  — use this in production
# =============================================================================

def predict_realtime(raw_sensor_dict: dict) -> dict:
    """
    Run a single real-time prediction on one CNC sensor reading.

    Parameters
    ----------
    raw_sensor_dict : dict
        Keys must include all 17 features used during training.
        Example:
            {
              'Yload': 4.41, 'Xload': -0.10, 'Zload': 2.3,
              'Zact': 2.1,   'Xact': -0.09,  'Yact': 4.2,
              'hour': 10,    'day_of_week': 2, 'shift': 1,
              'Yload_roll5': 4.30, 'Xload_roll5': -0.11,
              'Zload_roll5': 2.25, 'Zact_roll5': 2.05,
              'Xact_roll5': -0.08, 'speed': 3000,
              'status': 'active', 'tool_id': 12
            }

    Returns
    -------
    dict with keys: predicted_label, anomaly_probability, alert_level
    """
    model    = joblib.load(f'{OUTPUT_DIR}/gb_model.pkl')
    le       = joblib.load(f'{OUTPUT_DIR}/label_encoder_status.pkl')
    feat_col = joblib.load(f'{OUTPUT_DIR}/feature_cols.pkl')

    # Encode status
    raw_sensor_dict['status_enc'] = le.transform(
        [str(raw_sensor_dict.get('status', 'inactive'))]
    )[0]

    row   = pd.DataFrame([raw_sensor_dict])[feat_col].fillna(0)
    prob  = float(model.predict_proba(row)[0, 1])
    label = int(model.predict(row)[0])
    alert = get_alert_level(prob)

    return {
        'predicted_label'    : label,
        'anomaly_probability': round(prob, 4),
        'alert_level'        : alert,
    }


# Quick self-test of the inference function
print("\n[TEST] Real-time inference function:")
sample = {f: float(X_test[0, i]) for i, f in enumerate(FEATURES)}
# Reverse-encode status for the sample
sample['status'] = le_status.inverse_transform(
    [int(sample.pop('status_enc'))]
)[0]
result = predict_realtime(sample)
print(f"  Input  : {len(sample)} sensor features")
print(f"  Output : {result}")
print("\nDone. Ready for VS Code / Anaconda deployment.\n")
